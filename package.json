{
  "name": "cinna-tool-workspace",
  "private": true,
  "version": "1.0.0",
  "description": "CinnaTool desktop apps: Electron and Tauri editions.",
  "packageManager": "pnpm@11.5.2",
  "scripts": {
    "electron:dev": "pnpm --dir electron dev",
    "electron:build": "pnpm --dir electron build",
    "electron:dist:win": "pnpm --dir electron dist:win",
    "electron:build:mac": "pnpm --dir electron build:mac",
    "tauri:dev": "pnpm --dir tauri tauri:dev",
    "tauri:build": "pnpm --dir tauri tauri:build",
    "tauri:frontend:build": "pnpm --dir tauri build"
  },
  "workspaces": [
    "electron",
    "tauri"
  ]
}
