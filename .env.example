# CinnaTool 环境变量配置
#
# 本应用的 AI API Key 通过应用内设置面板配置，无需在此文件中设置。
# 以下为可选的开发/调试环境变量：

# Vite 开发服务器地址（开发模式下由 npm run dev 自动设置，通常无需手动配置）
# VITE_DEV_SERVER_URL=http://localhost:5173

# 如需自定义 OpenAI 兼容接口的默认 Base URL（可选，也可在应用内设置）
# OPENAI_API_BASE=https://api.openai.com/v1

# Supabase 账号系统
# 从 Supabase Project Settings -> API 获取 Project URL 和 anon/publishable key。
# 不要把 service_role key 放进前端环境变量。
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
